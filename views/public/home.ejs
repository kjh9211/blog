<%- include('../layout/header', { title }) %>

<div class="page-header">
  <h1>글 목록</h1>
</div>

<% if (posts.length === 0) { %>
  <p class="empty">아직 게시된 글이 없습니다.</p>
<% } else { %>
  <ul class="post-list">
    <% posts.forEach(post => { %>
      <li class="post-card">
        <a class="post-title" href="/post/<%= post.slug %>"><%= post.title %></a>
        <p class="post-excerpt"><%= post.excerpt.replace(/[#*`>_\[\]]/g, '').slice(0, 150) %><% if (post.excerpt.length >= 150) { %>…<% } %></p>
        <div class="post-meta">
          <span class="badge badge-<%= post.content_type %>"><%= post.content_type.toUpperCase() %></span>
          <time><%= new Date(post.created_at).toLocaleDateString('ko-KR') %></time>
        </div>
      </li>
    <% }) %>
  </ul>

  <% if (totalPages > 1) { %>
    <nav class="pagination">
      <% if (page > 1) { %><a href="/?page=<%= page - 1 %>">&larr; 이전</a><% } %>
      <span><%= page %> / <%= totalPages %></span>
      <% if (page < totalPages) { %><a href="/?page=<%= page + 1 %>">다음 &rarr;</a><% } %>
    </nav>
  <% } %>
<% } %>

<%- include('../layout/footer') %>
