<%- include('../layout/header', { title }) %>

<article class="post-article">
  <header class="post-header">
    <h1><%= post.title %></h1>
    <div class="post-meta">
      <span class="badge badge-<%= post.content_type %>"><%= post.content_type.toUpperCase() %></span>
      <time><%= new Date(post.created_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) %></time>
    </div>
  </header>
  <div class="post-content">
    <%- post.renderedContent %>
  </div>
</article>

<a class="back-link" href="/">&larr; 목록으로</a>

<%- include('../layout/footer') %>
