<%- include('../layout/admin-header', { title }) %>

<div class="page-header admin-page-header">
  <h1>포스트 관리</h1>
  <a href="/admin/posts/new" class="btn btn-primary">+ 새 글 작성</a>
</div>

<% if (posts.length === 0) { %>
  <p class="empty">작성된 포스트가 없습니다.</p>
<% } else { %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>제목</th>
        <th>형식</th>
        <th>상태</th>
        <th>작성일</th>
        <th>관리</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach(post => { %>
        <tr>
          <td><a href="/post/<%= post.slug %>" target="_blank"><%= post.title %></a></td>
          <td><span class="badge badge-<%= post.content_type %>"><%= post.content_type.toUpperCase() %></span></td>
          <td><span class="badge <%= post.published ? 'badge-published' : 'badge-draft' %>"><%= post.published ? '공개' : '비공개' %></span></td>
          <td><time><%= new Date(post.created_at).toLocaleDateString('ko-KR') %></time></td>
          <td class="actions">
            <a href="/admin/posts/<%= post.id %>/edit" class="btn btn-sm btn-secondary">수정</a>
            <form method="POST" action="/admin/posts/<%= post.id %>?_method=DELETE" onsubmit="return confirm('정말 삭제하시겠습니까?')">
              <button type="submit" class="btn btn-sm btn-danger">삭제</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../layout/admin-footer') %>
