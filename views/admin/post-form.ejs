<%- include('../layout/admin-header', { title }) %>

<div class="page-header admin-page-header">
  <h1><%= post ? '포스트 수정' : '새 포스트' %></h1>
</div>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form class="post-form" method="POST" action="<%= action %>">
  <div class="form-group">
    <label for="title">제목</label>
    <input id="title" type="text" name="title" class="form-input" value="<%= post ? post.title : '' %>" placeholder="포스트 제목" required>
  </div>

  <div class="form-group">
    <label for="slug">슬러그 (URL)</label>
    <input id="slug-display" type="text" class="form-input slug-preview" value="<%= post ? post.slug : '' %>" placeholder="자동 생성됩니다" readonly>
  </div>

  <div class="form-group">
    <label>형식</label>
    <div class="radio-group">
      <label class="radio-label">
        <input type="radio" name="content_type" value="markdown" <%= (!post || post.content_type === 'markdown') ? 'checked' : '' %>>
        Markdown
      </label>
      <label class="radio-label">
        <input type="radio" name="content_type" value="html" <%= (post && post.content_type === 'html') ? 'checked' : '' %>>
        HTML
      </label>
    </div>
    <span id="editor-mode-hint" class="form-hint">마크다운 형식으로 작성합니다.</span>
  </div>

  <div class="form-group">
    <label for="content">내용</label>
    <div class="editor-toolbar">
      <button type="button" id="img-upload-btn" class="btn btn-sm btn-secondary">이미지 업로드</button>
      <input type="file" id="img-file-input" accept="image/jpeg,image/png,image/gif,image/webp" style="display:none">
      <span id="img-upload-status" class="upload-status"></span>
    </div>
    <textarea id="content" name="content" class="form-textarea" rows="24" placeholder="내용을 입력하세요..." required><%= post ? post.content : '' %></textarea>
  </div>

  <div class="form-group form-check">
    <label class="check-label">
      <input type="checkbox" name="published" value="1" <%= (post && post.published) ? 'checked' : '' %>>
      공개 게시
    </label>
  </div>

  <div class="form-actions">
    <a href="/admin" class="btn btn-secondary">취소</a>
    <button type="submit" class="btn btn-primary">저장</button>
  </div>
</form>

<%- include('../layout/admin-footer') %>
